{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Matcha",
  "scopeName": "source.matcha",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#function-calls" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.matcha",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.matcha",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.matcha",
              "match": "\\\\[nrt\"\\\\]"
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(val|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.matcha" },
            "2": { "name": "variable.other.matcha" }
          }
        },
        {
          "match": "\\b(item)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.matcha" },
            "2": { "name": "entity.name.type.matcha" }
          }
        },
        {
          "match": "\\b(item)\\s+([a-z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.matcha" },
            "2": { "name": "entity.name.function.matcha" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.matcha",
          "match": "\\b(if|else|match|loop|while|for|in|leave|continue|return)\\b"
        },
        {
          "name": "keyword.operator.logical.matcha",
          "match": "\\b(not|and|or)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.matcha",
          "match": "\\b(item|val|var|structure)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.matcha",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.self.matcha",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.matcha",
          "match": "\\b(int|boolean|string|unit)\\b"
        },
        {
          "name": "entity.name.type.matcha",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.matcha",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.matcha",
          "match": "\\b[a-z][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.matcha",
          "match": "(=>|==|!=|<=|>=|\\+=|-=|\\*=|=|\\+|-|\\*|/|<|>|\\.|:|;|,)"
        }
      ]
    }
  }
}
